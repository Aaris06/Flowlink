<?xml version="1.0" encoding="utf-8"?>
<!--
  Border-only background for local video PiP SurfaceViewRenderer.
  Must have a TRANSPARENT fill — any solid colour over a SurfaceView
  will paint on top of the video surface and hide the camera preview.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <corners android:radius="12dp" />
    <stroke android:width="2dp" android:color="#AA6C63FF" />
</shape>
