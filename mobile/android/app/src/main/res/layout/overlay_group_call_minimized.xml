<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimized group-call bubble — floats over the app, draggable, tap to restore.
  Shows up to 3 participant avatar circles + an optional "+N" overflow badge,
  the participant count, and a timer on the right.
  Audio keeps playing because GroupCallFragment stays alive in the back stack.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gcm_bubble_root"
    android:layout_width="wrap_content"
    android:layout_height="56dp"
    android:minWidth="160dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:background="@drawable/call_pip_bg"
    android:elevation="32dp"
    android:clickable="true"
    android:focusable="true">

    <!--
      Avatar strip: up to 3 overlapping circles.
      Each is a TextView with the first letter of the participant's username.
      gcm_avatar_1 is always visible when ≥1 participant exists.
      gcm_avatar_2 / gcm_avatar_3 are shown when there are 2+ / 3+ remote participants.
    -->
    <FrameLayout
        android:id="@+id/gcm_avatar_strip"
        android:layout_width="wrap_content"
        android:layout_height="40dp">

        <!-- Avatar 1 (leftmost) -->
        <TextView
            android:id="@+id/gcm_avatar_1"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="0dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/call_avatar_bg"
            android:elevation="3dp"
            android:visibility="visible"/>

        <!-- Avatar 2 (shifted right, overlaps 1) -->
        <TextView
            android:id="@+id/gcm_avatar_2"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="20dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/call_avatar_bg"
            android:elevation="2dp"
            android:visibility="gone"/>

        <!-- Avatar 3 (shifted further right) -->
        <TextView
            android:id="@+id/gcm_avatar_3"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="40dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/call_avatar_bg"
            android:elevation="1dp"
            android:visibility="gone"/>

        <!-- Overflow badge "+N" (when >3 participants) -->
        <TextView
            android:id="@+id/gcm_avatar_overflow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="60dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/call_btn_bg_neutral"
            android:elevation="0dp"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- Info: participant count + timer -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/gcm_bubble_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Group Call"/>

        <TextView
            android:id="@+id/gcm_bubble_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:text="00:00"/>

    </LinearLayout>

    <!-- End / leave call button -->
    <FrameLayout
        android:id="@+id/gcm_bubble_btn_end"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/call_btn_bg_red"
        android:clickable="true"
        android:focusable="true"
        android:elevation="36dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </FrameLayout>

</LinearLayout>
