<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimized group-call bubble — attached to WindowManager so it floats
  above ALL fragments and persists through any navigation.

  For video calls: shows up to 2 SurfaceViewRenderer thumbnails (added
  programmatically) + an optional "+N" badge.
  For audio calls: shows up to 3 overlapping avatar letter circles.

  Tap body → restore call.  Tap ✕ → leave call.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gcm_bubble_root"
    android:layout_width="wrap_content"
    android:layout_height="64dp"
    android:minWidth="160dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:background="@drawable/call_pip_bg"
    android:clickable="true"
    android:focusable="true">

    <!--
      Media strip: either video thumbnails (video call) or avatar circles (audio).
      SurfaceViewRenderer tiles are added/removed programmatically.
      The FrameLayout is sized to fit up to 2 tiles (48dp each + 4dp gap = 100dp).
    -->
    <FrameLayout
        android:id="@+id/gcm_media_strip"
        android:layout_width="100dp"
        android:layout_height="52dp"
        android:clipChildren="false">

        <!-- Avatar 1 — shown for audio calls or when video is unavailable -->
        <TextView
            android:id="@+id/gcm_avatar_1"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="0dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/call_avatar_bg"
            android:elevation="3dp"
            android:visibility="gone"/>

        <!-- Avatar 2 -->
        <TextView
            android:id="@+id/gcm_avatar_2"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="24dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/call_avatar_bg"
            android:elevation="2dp"
            android:visibility="gone"/>

        <!-- Avatar 3 -->
        <TextView
            android:id="@+id/gcm_avatar_3"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="48dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/call_avatar_bg"
            android:elevation="1dp"
            android:visibility="gone"/>

        <!--
          "+N more" overflow badge — positioned over the right edge of the strip.
          Shown when there are more remote participants than visible tiles.
        -->
        <TextView
            android:id="@+id/gcm_overflow_badge"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical|end"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/call_btn_bg_neutral"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- Info column: participant count + timer -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/gcm_bubble_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Group Call"/>

        <TextView
            android:id="@+id/gcm_bubble_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:text="00:00"/>

    </LinearLayout>

    <!-- Leave call button -->
    <FrameLayout
        android:id="@+id/gcm_bubble_btn_end"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/call_btn_bg_red"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </FrameLayout>

</LinearLayout>
