<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimized call bubble — floats over the app, draggable, tap to restore.
  For audio calls: shows pulsing avatar circle.
  For video calls: shows live local camera feed in the circle.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bubble_root"
    android:layout_width="80dp"
    android:layout_height="80dp"
    android:elevation="32dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Circular clip container -->
    <FrameLayout
        android:id="@+id/bubble_circle"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bubble_call_bg"
        android:clipToOutline="true">

        <!-- Video preview (video calls only) — fills the circle -->
        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/bubble_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Audio avatar (audio calls, or when camera off) -->
        <LinearLayout
            android:id="@+id/bubble_audio_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bubble_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/call_avatar_bg" />
        </LinearLayout>

        <!-- Dark scrim at bottom for text -->
        <View
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_gravity="bottom"
            android:background="@drawable/call_bottom_scrim" />

        <!-- Timer at bottom of circle -->
        <TextView
            android:id="@+id/bubble_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingBottom="5dp" />

    </FrameLayout>

    <!-- End call button — small circle at top-right -->
    <FrameLayout
        android:id="@+id/bubble_btn_end"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-2dp"
        android:layout_marginEnd="-2dp"
        android:background="@drawable/call_btn_bg_red"
        android:clickable="true"
        android:focusable="true"
        android:elevation="36dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </FrameLayout>

</FrameLayout>
