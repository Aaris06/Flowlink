<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0C29"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:text="⚡"
                android:textSize="26sp"
                android:gravity="center"
                android:background="@drawable/share_fab_bg"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FlowLink"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cross-Device Continuity"
                    android:textColor="#6B6890"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="24dp">

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/glass_card_bg_dark"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tab_login"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Sign In"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/share_fab_bg" />

                <TextView
                    android:id="@+id/tab_signup"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Sign Up"
                    android:gravity="center"
                    android:textColor="#6B6890"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Username -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USERNAME"
                android:textColor="#6B6890"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_auth_username"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_card_bg_dark"
                android:textColor="#FFFFFF"
                android:textColorHint="#44FFFFFF"
                android:hint="Enter your username"
                android:paddingHorizontal="14dp"
                android:inputType="text"
                android:layout_marginBottom="16dp" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="#6B6890"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_auth_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_card_bg_dark"
                android:textColor="#FFFFFF"
                android:textColorHint="#44FFFFFF"
                android:hint="Enter your password"
                android:paddingHorizontal="14dp"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp" />

            <!-- Confirm Password (signup only) -->
            <TextView
                android:id="@+id/tv_confirm_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRM PASSWORD"
                android:textColor="#6B6890"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_auth_confirm"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_card_bg_dark"
                android:textColor="#FFFFFF"
                android:textColorHint="#44FFFFFF"
                android:hint="Confirm your password"
                android:paddingHorizontal="14dp"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Error -->
            <TextView
                android:id="@+id/tv_auth_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FCA5A5"
                android:textSize="13sp"
                android:background="@drawable/glass_card_bg_dark"
                android:padding="10dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/auth_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Submit -->
            <Button
                android:id="@+id/btn_auth_submit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign In"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/share_fab_bg"
                android:layout_marginTop="4dp" />

            <!-- Switch mode -->
            <TextView
                android:id="@+id/tv_auth_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New to FlowLink? Sign up"
                android:textColor="#A78BFA"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="4dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
