<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE0F0C29">

    <!-- Main layout: header + video area + controls stacked vertically -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: title, participant count, status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#CC1A1A2E">

            <TextView
                android:id="@+id/gcf_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Group Call"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0"
                android:gravity="center"/>

            <TextView
                android:id="@+id/gcf_participants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/gcf_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connecting…"
                android:textSize="13sp"
                android:textColor="#A78BFA"
                android:gravity="center"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!--
            Video grid container.
            This is a VERTICAL LinearLayout that receives rows programmatically.
            Each row is a horizontal LinearLayout with equal-weight tiles.
            weight=1 makes it fill remaining space between header and controls.
        -->
        <LinearLayout
            android:id="@+id/gcf_video_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#0D0D1A"/>

        <!-- Controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"
            android:background="#CC1A1A2E">

            <!-- Accept (only when ringing_in) -->
            <ImageButton
                android:id="@+id/gcf_btn_accept"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/call_btn_bg_green"
                android:src="@android:drawable/ic_menu_call"
                android:contentDescription="Accept call"
                android:visibility="gone"/>

            <!-- Mute -->
            <ImageButton
                android:id="@+id/gcf_btn_mute"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/call_btn_bg_neutral"
                android:src="@drawable/ic_mic"
                android:contentDescription="Toggle mute"
                android:visibility="gone"/>

            <!-- Speaker -->
            <ImageButton
                android:id="@+id/gcf_btn_speaker"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/call_btn_bg_neutral"
                android:src="@android:drawable/ic_lock_silent_mode"
                android:contentDescription="Toggle speaker"
                android:visibility="gone"/>

            <!-- Camera toggle -->
            <ImageButton
                android:id="@+id/gcf_btn_camera"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/call_btn_bg_neutral"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Toggle camera"
                android:visibility="gone"/>

            <!-- Leave / end -->
            <ImageButton
                android:id="@+id/gcf_btn_end"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/call_btn_bg_red"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Leave call"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Local video PiP: floating overlay in bottom-right of the video area -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/gcf_local_pip"
        android:layout_width="110dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/call_pip_bg"
        android:elevation="8dp"
        android:visibility="gone"/>

</FrameLayout>
