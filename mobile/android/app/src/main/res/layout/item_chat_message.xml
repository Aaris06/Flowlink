<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="3dp">

    <!-- Sender name (incoming only) -->
    <TextView
        android:id="@+id/tv_sender_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#A78BFA"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingHorizontal="4dp"
        android:paddingBottom="2dp"
        android:visibility="gone" />

    <!-- Bubble container (gravity set in code) -->
    <FrameLayout
        android:id="@+id/bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="300dp">

        <LinearLayout
            android:id="@+id/bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:minWidth="160dp"
            android:maxWidth="300dp">

            <!-- Reply preview strip -->
            <LinearLayout
                android:id="@+id/reply_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#33A78BFA"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:layout_marginBottom="0dp"
                android:visibility="gone">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="#A78BFA"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_reply_preview"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="11sp"
                    android:textColor="#D4B8FF"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- File attachment card (WhatsApp style) -->
            <LinearLayout
                android:id="@+id/file_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Image preview (for images only) -->
                <ImageView
                    android:id="@+id/iv_image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- Voice message player row -->
                <LinearLayout
                    android:id="@+id/voice_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:visibility="gone">

                    <!-- Play/Pause button -->
                    <FrameLayout
                        android:id="@+id/btn_voice_play"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/glass_card_bg_dark"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="10dp">
                        <TextView
                            android:id="@+id/tv_voice_play_icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="▶"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                    </FrameLayout>

                    <!-- Waveform placeholder + duration -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/voice_progress_bar"
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:background="#44FFFFFF"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_voice_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_voice_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAFFFFFF"
                        android:textSize="10sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- File row (icon + name + download) -->
                <LinearLayout
                    android:id="@+id/file_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp">

                    <!-- Colored file type icon -->
                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="10dp">

                        <View
                            android:id="@+id/file_icon_bg"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/share_fab_bg" />

                        <TextView
                            android:id="@+id/tv_file_type_badge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="P"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <!-- File name + meta -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_file_name_bubble"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:maxLines="2" />

                        <TextView
                            android:id="@+id/tv_file_meta_bubble"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Download circle button -->
                    <FrameLayout
                        android:id="@+id/btn_file_download"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/glass_card_bg_dark"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="↓"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Text message -->
            <TextView
                android:id="@+id/tv_message_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.3"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <!-- Call activity card -->
            <LinearLayout
                android:id="@+id/call_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_call_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_call_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btn_join_call"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Join Call" />
            </LinearLayout>

            <!-- Time + ticks row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="end"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:paddingTop="2dp">

                <TextView
                    android:id="@+id/tv_message_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#AAFFFFFF" />

                <TextView
                    android:id="@+id/tv_ticks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#AAFFFFFF"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Hidden legacy view (kept for adapter compat) -->
    <TextView
        android:id="@+id/tv_file_attachment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
