<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@drawable/glass_card_bg">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/glass_card_bg_dark"
            android:tint="#FFFFFF"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🛡️  Admin Panel"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/admin_progress"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/glass_card_bg_dark">

        <TextView
            android:id="@+id/tab_users"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="👤 Users"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/share_fab_bg" />

        <TextView
            android:id="@+id/tab_sessions"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🔗 Sessions"
            android:gravity="center"
            android:textColor="#6B6890"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_feedback"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📝 Reports"
            android:gravity="center"
            android:textColor="#6B6890"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_announce"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📢 Announce"
            android:gravity="center"
            android:textColor="#6B6890"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Status message -->
            <TextView
                android:id="@+id/tv_admin_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#86EFAC"
                android:textSize="13sp"
                android:padding="10dp"
                android:background="@drawable/glass_card_bg_dark"
                android:layout_marginBottom="10dp"
                android:visibility="gone" />

            <!-- Users list -->
            <LinearLayout
                android:id="@+id/panel_users"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tv_users_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Registered Users"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_refresh_users"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↻ Refresh"
                        android:textColor="#A78BFA"
                        android:textSize="13sp"
                        android:padding="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/list_users"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Sessions list -->
            <LinearLayout
                android:id="@+id/panel_sessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Active Sessions"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_refresh_sessions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↻ Refresh"
                        android:textColor="#A78BFA"
                        android:textSize="13sp"
                        android:padding="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/list_sessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Feedback list -->
            <LinearLayout
                android:id="@+id/panel_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Feedback &amp; Reports"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_refresh_feedback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↻ Refresh"
                        android:textColor="#A78BFA"
                        android:textSize="13sp"
                        android:padding="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/list_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Announce panel -->
            <LinearLayout
                android:id="@+id/panel_announce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send Announcement to All Users"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Type selector -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/type_info"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="ℹ Info"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@drawable/share_fab_bg"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/type_update"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="🚀 Update"
                        android:gravity="center"
                        android:textColor="#6B6890"
                        android:textSize="13sp"
                        android:background="@drawable/glass_card_bg_dark"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/type_warning"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="⚠ Warning"
                        android:gravity="center"
                        android:textColor="#6B6890"
                        android:textSize="13sp"
                        android:background="@drawable/glass_card_bg_dark" />
                </LinearLayout>

                <EditText
                    android:id="@+id/et_announce_title"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/glass_card_bg_dark"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#44FFFFFF"
                    android:hint="Title (e.g. New Feature Released!)"
                    android:paddingHorizontal="14dp"
                    android:inputType="text"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/et_announce_msg"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/glass_card_bg_dark"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#44FFFFFF"
                    android:hint="Message body…"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_send_announce"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="📢 Send to All Users"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/share_fab_bg" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
